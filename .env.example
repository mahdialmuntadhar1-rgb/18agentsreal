# Frontend (Vite)
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"
VITE_OPERATOR_EMAIL="ops@example.com"

# Runtime (API + workers)
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
GEMINI_API_KEY="your-gemini-key"

# Runtime process mode: worker | api | all (guardrails validate env + schema on boot)
RUNTIME_MODE="worker"
PORT="4100"

# Worker identity / scope
AGENT_ID="agent-01"
AGENT_NAME="Agent-01"
AGENT_SCOPE="Baghdad"

# Worker tuning
WORKER_POLL_MS="3000"
WORKER_HEARTBEAT_MS="10000"
WORKER_STALE_MS="120000"

# Multi-worker launcher (used by npm run runtime:workers:scoped)
WORKER_SCOPES="Baghdad,Basra,Erbil"
AGENT_NAME_PREFIX="agent"

# Bootstrap utility
RUNTIME_API_URL="http://localhost:4100"
SEED_GOVERNORATES="Baghdad,Basra"
SEED_CITIES="Baghdad,Basra"
SEED_CATEGORIES="restaurants,cafes"
SEED_MAX_ATTEMPTS="3"
